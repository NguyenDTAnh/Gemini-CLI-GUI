{
  "name": "gemini-cli-chat-ext",
  "displayName": "Gemini CLI Chat",
  "description": "Interactive chat UI in VS Code backed by local Gemini CLI.",
  "version": "1.0.0",
  "publisher": "local",
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "geminiCliChat",
          "title": "Gemini",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "geminiCliChat": [
        {
          "id": "geminiCliChat.views.main",
          "name": "Chat",
          "type": "webview",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "commands": [
      {
        "command": "geminiCliChat.openChat",
        "title": "Gemini Chat: Focus Chat"
      },
      {
        "command": "geminiCliChat.newSession",
        "title": "Gemini Chat: New Session"
      },
      {
        "command": "geminiCliChat.stopGeneration",
        "title": "Gemini Chat: Stop Generation"
      },
      {
        "command": "geminiCliChat.attachActiveFile",
        "title": "Gemini Chat: Attach Active File"
      },
      {
        "command": "geminiCliChat.clearSessions",
        "title": "Gemini Chat: Clear All Sessions"
      },
      {
        "command": "geminiCliChat.insertSelectedContext",
        "title": "Gemini Chat: Add Selected Context"
      }
    ],
    "keybindings": [
      {
        "command": "geminiCliChat.insertSelectedContext",
        "key": "ctrl+shift+i",
        "mac": "cmd+shift+i",
        "when": "editorTextFocus && editorHasSelection"
      }
    ],
    "configuration": {
      "title": "Gemini CLI Chat",
      "properties": {
        "geminiCliChat.cliPath": {
          "type": "string",
          "default": "gemini",
          "description": "Path to Gemini CLI binary."
        },
        "geminiCliChat.defaultArgs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Default arguments appended to each Gemini CLI request. Use {{prompt}} to inject full prompt payload into args instead of stdin."
        },
        "geminiCliChat.availableModels": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "gemini-3.1-pro-preview",
            "gemini-3-flash-preview",
            "gemini-3.1-flash-lite-preview",
            "gemini-2.5-pro",
            "gemini-2.5-flash",
            "gemini-2.5-flash-lite"
          ],
          "description": "Model list shown in chat UI selector. Values are passed to --model."
        },
        "geminiCliChat.availableAgents": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "description": "Unique identifier for the agent."
              },
              "label": {
                "type": "string",
                "description": "Display name of the agent."
              },
              "description": {
                "type": "string",
                "description": "Short description of the agent's purpose."
              }
            },
            "required": [
              "id",
              "label"
            ]
          },
          "default": [
            {
              "id": "codebase_investigator",
              "label": "Investigator",
              "description": "Phân tích codebase sâu"
            },
            {
              "id": "cli_help",
              "label": "CLI Helper",
              "description": "Tra cứu Gemini CLI"
            },
            {
              "id": "generalist",
              "label": "Generalist",
              "description": "Tác vụ đa năng"
            }
          ],
          "description": "Agent list shown in chat UI selector."
        },
        "geminiCliChat.customSlashCommands": {
          "type": "object",
          "default": {},
          "description": "Custom slash workflows map. Example: { \"refactor\": \"Suggest a safe refactor plan\" }."
        },
        "geminiCliChat.maxContextChars": {
          "type": "number",
          "default": 16000,
          "minimum": 1000,
          "description": "Maximum character budget for attached file context."
        },
        "geminiCliChat.maxAttachedFiles": {
          "type": "number",
          "default": 5,
          "minimum": 1,
          "maximum": 20,
          "description": "Maximum files attached in one request."
        },
        "geminiCliChat.maxDroppedFileBytes": {
          "type": "number",
          "default": 5242880,
          "minimum": 1024,
          "description": "Maximum bytes allowed per dropped file in composer."
        },
        "geminiCliChat.requestTimeoutMs": {
          "type": "number",
          "default": 120000,
          "minimum": 10000,
          "description": "Timeout in milliseconds for a Gemini CLI request."
        },
        "geminiCliChat.responseLanguage": {
          "type": "string",
          "default": "vi",
          "description": "Language hint appended to prompts."
        }
      }
    }
  },
  "scripts": {
    "build": "npm --prefix ../webview run build && npm run build:extension",
    "build:extension": "tsc -p .",
    "lint": "eslint . --ext .ts",
    "watch": "tsc -p . -w",
    "prepackage": "npm run build",
    "package": "npm run prepackage && npx @vscode/vsce package",
    "test": "npm run build:extension && node --test ../tests/unit/*.test.cjs ../tests/integration/*.test.cjs"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^20.14.12",
    "@types/vscode": "^1.95.0",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "@vscode/test-electron": "^2.4.1",
    "@vscode/vsce": "^3.3.2",
    "eslint": "^10.2.1",
    "globals": "^17.5.0",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.58.2"
  },
  "dependencies": {
    "fuse.js": "^7.3.0"
  }
}
